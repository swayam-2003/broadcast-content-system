{
  "info": {
    "_postman_id": "broadcast-content-system-complete",
    "name": "Broadcast Content System - Complete Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API testing collection with real-time rotation scenarios"
  },
  "item": [
    {
      "name": "SETUP - Health & Auth",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verify server is running - Expected: 200 OK"
          }
        },
        {
          "name": "Register Teacher",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@school.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"Ms. Sarah Smith\",\n  \"role\": \"teacher\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Save user.id as {{teacherId}}"
          }
        },
        {
          "name": "Register Principal",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@school.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"Mr. James Johnson\",\n  \"role\": \"principal\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Teacher Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@school.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Save token as {{authToken}}"
          }
        },
        {
          "name": "Principal Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@school.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Save token as {{principalToken}}"
          }
        }
      ]
    },
    {
      "name": "TEACHER - Upload Content",
      "item": [
        {
          "name": "Upload: Maths Content A (5 min)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file","type": "file","src": []},
                {"key": "title","value": "Calculus Basics - Derivatives"},
                {"key": "subject","value": "maths"},
                {"key": "description","value": "Introduction to derivative concepts"},
                {"key": "startTime","value": "2026-04-27T00:00:00Z"},
                {"key": "endTime","value": "2026-04-27T23:59:59Z"},
                {"key": "rotationOrder","value": "0"},
                {"key": "rotationDuration","value": "5"}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "upload"]
            },
            "description": "Save content.id as {{contentId1}}"
          }
        },
        {
          "name": "Upload: Maths Content B (3 min)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file","type": "file","src": []},
                {"key": "title","value": "Calculus Advanced - Chain Rule"},
                {"key": "subject","value": "maths"},
                {"key": "description","value": "Complex derivative calculations"},
                {"key": "startTime","value": "2026-04-27T00:00:00Z"},
                {"key": "endTime","value": "2026-04-27T23:59:59Z"},
                {"key": "rotationOrder","value": "1"},
                {"key": "rotationDuration","value": "3"}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "upload"]
            },
            "description": "Save content.id as {{contentId2}} - Rotation Order: 1"
          }
        },
        {
          "name": "Upload: Science Content (4 min)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file","type": "file","src": []},
                {"key": "title","value": "Physics - Newton's Laws"},
                {"key": "subject","value": "science"},
                {"key": "description","value": "Understanding forces and motion"},
                {"key": "startTime","value": "2026-04-27T00:00:00Z"},
                {"key": "endTime","value": "2026-04-27T23:59:59Z"},
                {"key": "rotationOrder","value": "0"},
                {"key": "rotationDuration","value": "4"}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "upload"]
            },
            "description": "Save content.id as {{contentId3}} - Different subject"
          }
        },
        {
          "name": "View My Uploaded Content",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/content/my-content",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "my-content"]
            },
            "description": "View all uploaded content - Should be 'pending'"
          }
        }
      ]
    },
    {
      "name": "PRINCIPAL - Approval Workflow",
      "item": [
        {
          "name": "View Pending Content",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/approval/pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "approval", "pending"]
            },
            "description": "Should show 3 pending items"
          }
        },
        {
          "name": "Approve: Maths Content A",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}, {"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{}"},
            "url": {
              "raw": "{{baseUrl}}/api/approval/approve/{{contentId1}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "approval", "approve", "{{contentId1}}"]
            }
          }
        },
        {
          "name": "Approve: Maths Content B",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}, {"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{}"},
            "url": {
              "raw": "{{baseUrl}}/api/approval/approve/{{contentId2}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "approval", "approve", "{{contentId2}}"]
            }
          }
        },
        {
          "name": "Approve: Science Content",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}, {"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{}"},
            "url": {
              "raw": "{{baseUrl}}/api/approval/approve/{{contentId3}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "approval", "approve", "{{contentId3}}"]
            }
          }
        },
        {
          "name": "View All Content",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/approval/all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "approval", "all"]
            },
            "description": "All 3 should show status: 'approved'"
          }
        }
      ]
    },
    {
      "name": "PUBLIC API - ROTATION (No Auth)",
      "item": [
        {
          "name": "ROTATION TEST 1: Initial State",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/content/live/{{teacherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "live", "{{teacherId}}"]
            },
            "description": "Expected: Maths A + Science showing"
          }
        },
        {
          "name": "ROTATION TEST 2: Check Rotation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/content/live/{{teacherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "live", "{{teacherId}}"]
            },
            "description": "Expected: Maths B now (rotation happened!)"
          }
        },
        {
          "name": "ROTATION TEST 3: Check Looping",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/content/live/{{teacherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "live", "{{teacherId}}"]
            },
            "description": "Expected: Maths A back (looping)"
          }
        },
        {
          "name": "ROTATION TEST 4: Check Consistency",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/content/live/{{teacherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "live", "{{teacherId}}"]
            },
            "description": "Expected: Maths B again"
          }
        }
      ]
    },
    {
      "name": "ANALYTICS - Content Tracking",
      "item": [
        {
          "name": "Get Overall Subject Statistics",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "stats"]
            },
            "description": "Shows total accesses per subject"
          }
        },
        {
          "name": "Get Most Active Subject",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/most-active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "most-active"]
            },
            "description": "Shows most popular subject"
          }
        },
        {
          "name": "Get Teacher's Own Statistics",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{teacherToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/teacher-stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "teacher-stats"]
            },
            "description": "Teacher views own content stats"
          }
        },
        {
          "name": "Get Specific Content Statistics",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/content/{{contentId1}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "content", "{{contentId1}}"]
            },
            "description": "Shows how many times a specific content was accessed"
          }
        },
        {
          "name": "Get Trending Content",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/trending?days=7",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "trending"]
            },
            "description": "Top 10 most accessed content last 7 days"
          }
        }
      ]
    },
    {
      "name": "ERROR TESTING - RBAC & Validation",
      "item": [
        {
          "name": "RBAC Test 1: Teacher Tries to Approve",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}, {"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{}"},
            "url": {
              "raw": "{{baseUrl}}/api/approval/approve/{{contentId1}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "approval", "approve", "{{contentId1}}"]
            },
            "description": "Expected: 403 Forbidden"
          }
        },
        {
          "name": "RBAC Test 2: Principal Tries to Upload",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{principalToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [{"key": "file","type": "file","src": []}, {"key": "title","value": "Test"}, {"key": "subject","value": "maths"}, {"key": "startTime","value": "2026-04-27T00:00:00Z"}, {"key": "endTime","value": "2026-04-27T23:59:59Z"}]
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "upload"]
            },
            "description": "Expected: 403 Forbidden"
          }
        },
        {
          "name": "Validation Test: Missing Title",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [{"key": "file","type": "file","src": []}, {"key": "subject","value": "maths"}, {"key": "startTime","value": "2026-04-27T00:00:00Z"}, {"key": "endTime","value": "2026-04-27T23:59:59Z"}]
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "upload"]
            },
            "description": "Expected: 400 Bad Request"
          }
        },
        {
          "name": "Validation Test: Invalid File Type",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [{"key": "file","type": "file","src": []}, {"key": "title","value": "PDF Doc"}, {"key": "subject","value": "maths"}, {"key": "startTime","value": "2026-04-27T00:00:00Z"}, {"key": "endTime","value": "2026-04-27T23:59:59Z"}]
            },
            "url": {
              "raw": "{{baseUrl}}/api/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "upload"]
            },
            "description": "Expected: 400 Bad Request - Invalid file type"
          }
        },
        {
          "name": "Edge Case: No Content Available",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/content/live/invalid-teacher-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "content", "live", "invalid-teacher-id"]
            },
            "description": "Expected: 200 OK with empty content array"
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "baseUrl","value": "http://localhost:3000","type": "string"},
    {"key": "authToken","value": "","type": "string","description": "Teacher JWT token"},
    {"key": "principalToken","value": "","type": "string","description": "Principal JWT token"},
    {"key": "teacherId","value": "","type": "string","description": "Teacher ID"},
    {"key": "contentId1","value": "","type": "string","description": "Maths Content A ID"},
    {"key": "contentId2","value": "","type": "string","description": "Maths Content B ID"},
    {"key": "contentId3","value": "","type": "string","description": "Science Content ID"}
  ]
}
